# Hermetic sandbox for testing the install/uninstall UX changes in PR #105.
#
# Goals:
#   - Fresh ~/.config and ~/.local on every `podman run` (no state leakage
#     between test attempts)
#   - Real `ollama` binary (so pull_models auto-spawn + uninstall PID-targeted
#     stop actually exercise process management code, not mocks)
#   - Live-mount the host's skillsmith checkout so iterating on the PR
#     doesn't require rebuilding the image
#   - No systemd (skillsmith setup is run with --service manual so we don't
#     fight container init)
#
# Build:    podman build -t skillsmith-sandbox -f tests/sandbox/Containerfile .
# Run:      see tests/sandbox/README.md
FROM python:3.12-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates procps less jq git build-essential cmake \
    && rm -rf /var/lib/apt/lists/*

# Pinning to a recent ollama release. Direct binary download — the official
# install.sh script wants systemd, which we don't have.
ARG OLLAMA_VERSION=v0.5.4
RUN curl -fsSL "https://ollama.com/download/ollama-linux-amd64.tgz" \
    | tar -xz -C /usr/local

# uv: fast Python installer used by skillsmith's tooling.
RUN curl -LsSf https://astral.sh/uv/install.sh | sh && \
    cp /root/.local/bin/uv /usr/local/bin/uv

# Helpful default working dir.
WORKDIR /work

# Source is mounted at /src by the runner — install editable so source
# edits on the host are picked up without rebuilding.
ENV SKILLSMITH_SRC=/src

# Helpers + smoke test scripts live next to this Containerfile and get
# mounted in via the run command.
ENV PATH=/sandbox:$PATH

# bash by default — let the user drive.
CMD ["/bin/bash"]
