# skillsmith — environment template
#
# Copy to .env and uncomment / adjust as needed.
# Or copy a platform preset: cp .env.cpu .env
#
# See .env.strix-point  — AMD Strix Point NPU + iGPU (original dev workstation)
# See .env.cpu          — Universal CPU+RAM (any machine, no accelerator)
# See .env.apple-silicon — Apple Silicon (Metal / MLX via Ollama)
# See .env.nvidia       — NVIDIA GPU (CUDA via Ollama or vLLM)

# --- Storage (same for all platforms) ---
LADYBUG_DB_PATH=./data/ladybug
DUCKDB_PATH=./data/skills.duck
LOG_LEVEL=INFO

# --- Runtime embeddings (retrieve / compose) ---
# Point at whichever OpenAI-compatible embedding server you run.
# All embedding models must produce 768-dim vectors.
RUNTIME_EMBED_BASE_URL=http://localhost:11434
RUNTIME_EMBEDDING_MODEL=embeddinggemma

# --- Authoring pipeline (skill generation + QA — optional) ---
# Only needed if you author new skills. Skippable for runtime-only use.
LM_STUDIO_BASE_URL=http://localhost:1234
AUTHORING_EMBED_BASE_URL=http://localhost:1234
AUTHORING_MODEL=qwen/qwen3.6-35b-a3b
CRITIC_MODEL=qwen/qwen3.6-35b-a3b
AUTHORING_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# --- Dedup / QA tuning ---
DEDUP_HARD_THRESHOLD=0.92
DEDUP_SOFT_THRESHOLD=0.80
BOUNCE_BUDGET=3
