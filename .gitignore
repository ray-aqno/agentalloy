# Track pre-seeded corpus (src/skillsmith/_corpus/skills.duck + ladybug/) so a
# fresh clone is a working install. The corpus ships inside the wheel as
# package data; on first run it's copied to the user data dir. Ignore
# runtime telemetry, per-install scratch, and any tmp build artifacts.
src/skillsmith/_corpus/**/*-shm
src/skillsmith/_corpus/**/*-wal
data/
!src/skillsmith/_corpus/
*.db
*.sqlite
*.sqlite3

# POC harness generates per-run output artifacts; reproducible from the harness
eval/runs/

