# Platform preset: Apple Silicon (M1/M2/M3/M4 — Metal acceleration)
#
# Hardware: Any Apple Silicon Mac.
#   Ollama uses Metal (GPU) for both embedding and generation.
#   Alternatively, use LM Studio with llama.cpp Metal backend.
#
# RAM minimum: 8 GB unified memory (embed + small generation model)
#   16 GB recommended for authoring with larger models (14B+).
#
# Setup:
#   1. Install Ollama — https://ollama.com (native ARM64 build)
#   2. ollama pull embeddinggemma
#   3. ollama pull qwen3.5:0.8b           # or qwen3.5:4b / :9b if RAM allows
#   4. ollama serve                        # default :11434
#   5. cp .env.apple-silicon .env
#
# Notes:
#   - Ollama on Apple Silicon uses Metal automatically. No extra config.
#   - embeddinggemma (EmbeddingGemma 300M) produces 768-dim vectors
#     (matches schema). Only ~622 MB on disk.
#   - For higher throughput, use LM Studio with its Metal backend
#     and change the URLs to http://localhost:1234.
#   - MLX-based servers (e.g. mlx-lm) also expose OpenAI-compatible
#     endpoints and work without code changes — just update the URLs.

# Storage
LADYBUG_DB_PATH=./data/ladybug
DUCKDB_PATH=./data/skills.duck
LOG_LEVEL=INFO

# Runtime embeddings — Ollama with Metal
RUNTIME_EMBED_BASE_URL=http://localhost:11434
RUNTIME_EMBEDDING_MODEL=embeddinggemma

# Authoring pipeline — Ollama with Metal
LM_STUDIO_BASE_URL=http://localhost:11434
AUTHORING_EMBED_BASE_URL=http://localhost:11434
AUTHORING_MODEL=qwen3.5:0.8b
CRITIC_MODEL=qwen3.5:0.8b
AUTHORING_EMBEDDING_MODEL=embeddinggemma

# Dedup / QA
DEDUP_HARD_THRESHOLD=0.92
DEDUP_SOFT_THRESHOLD=0.80
BOUNCE_BUDGET=3
