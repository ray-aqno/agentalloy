# Platform preset: AMD Strix Point (NPU + iGPU)
#
# Hardware: AMD Ryzen AI 300 series (Strix Point)
#   NPU  → FastFlowLM serving embed-gemma:300m (always-resident, no contention)
#   iGPU → LM Studio serving inference models (Qwen MoE, coder, etc.)
#
# RAM minimum: 16 GB system + 8 GB VRAM (shared)
#
# Setup:
#   1. Install FastFlowLM — https://fastflowlm.ai
#   2. Load embed-gemma:300m on NPU (default port 52625)
#   3. Install LM Studio — https://lmstudio.ai
#   4. Load qwen/qwen3.6-35b-a3b in LM Studio
#   5. cp .env.strix-point .env

# Storage
LADYBUG_DB_PATH=./data/ladybug
DUCKDB_PATH=./data/skills.duck
LOG_LEVEL=INFO

# Runtime embeddings — NPU via FastFlowLM
RUNTIME_EMBED_BASE_URL=http://127.0.0.1:52625
RUNTIME_EMBEDDING_MODEL=embed-gemma:300m

# Authoring pipeline — iGPU via LM Studio (big models), NPU via FastFlowLM (embeddings)
LM_STUDIO_BASE_URL=http://localhost:1234
AUTHORING_EMBED_BASE_URL=http://127.0.0.1:52625
AUTHORING_MODEL=qwen/qwen3.6-35b-a3b
CRITIC_MODEL=qwen/qwen3.6-35b-a3b
AUTHORING_EMBEDDING_MODEL=embed-gemma:300m

# Dedup / QA
DEDUP_HARD_THRESHOLD=0.92
DEDUP_SOFT_THRESHOLD=0.80
BOUNCE_BUDGET=3
